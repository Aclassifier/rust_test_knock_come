{
    // 1. Show the directory in the VS Code file explorer
    "files.exclude": {
        "src_frozen_versions": false
    },

    // 2. Save CPU resources by stopping VS Code from watching background changes
    "files.watcherExclude": {
        "**/src_frozen_versions/**": true
    },

    // 3. Prevent any accidental editing by locking the files as Read-Only
    "files.readonlyInclude": {
        "**/src_frozen_versions/**": true
    },

    // 4. Tell rust-analyzer to completely ignore this directory
    "rust-analyzer.files.excludeDirs": [
        "src_frozen_versions"
    ]
}
